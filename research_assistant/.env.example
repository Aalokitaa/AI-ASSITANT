# ==============================================================================
# AI Research Assistant Configuration Environment Variables
# ==============================================================================

# Core LLM Keys
GOOGLE_API_KEY=your_gemini_api_key_here
# Note: Google Gemini models (gemini-1.5-pro and gemini-1.5-flash) will be used

# Vector Database Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
# Note: For Serverless indexes, environment is usually not required in the new SDK,
# but can be specified if using Pod-based indexes (e.g., us-east-1, us-west1-gcp)
PINECONE_INDEX_NAME=research-assistant

# Web Search API configuration
# We use Tavily Search API for clean, search-optimized LLM results
TAVILY_API_KEY=your_tavily_api_key_here

# Server Configuration
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
